__pycache__/
*.pyc
.venv/
.pytest_cache/

# Generated datasets: keep directory README files and metadata/checksums only.
data/raw/**/*
data/interim/**/*
data/processed/**/*
!data/raw/**/README.md
!data/interim/**/README.md
!data/processed/**/README.md
!data/raw/**/*.sha256
!data/raw/**/metadata.json
!data/raw/**/LICENCE.md

